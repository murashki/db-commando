{
  "name": "db-commando",
  "version": "0.1.6",
  "author": "Yakov Dalinchuk <yakov.dalinchuk@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/src/index.d.ts"
    },
    "./dbTableConstructor": {
      "import": "./dist/esm/dbTableConstructor.js",
      "require": "./dist/cjs/dbTableConstructor.cjs",
      "types": "./dist/src/dbTableConstructor/index.d.ts"
    },
    "./modules": {
      "import": "./dist/esm/modules.js",
      "require": "./dist/cjs/modules.cjs",
      "types": "./dist/src/modules/index.d.ts"
    },
    "./tools": {
      "import": "./dist/esm/tools.js",
      "require": "./dist/cjs/tools.cjs",
      "types": "./dist/src/tools/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clear-dist && rollup --config ./rollup.config.js",
    "clear-dist": "rm -rf dist",
    "examples:run": "tsx --tsconfig ./tsconfig.json ./examples/index.ts",
    "prepublishOnly": "npm run build",
    "ts-lint:watch": "tsc --noEmit --watch --project ./tsconfig.json"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "proprompt": "^0.1.8",
    "sql-formatter": "^15.7.3",
    "sql-highlight": "^6.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
